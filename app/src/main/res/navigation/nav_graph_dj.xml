<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/nav_graph_dj"
    app:startDestination="@id/dashboardDJ">

    <fragment
        android:id="@+id/formDJ"
        android:name="com.example.bpmnow.ui.dj.formDJ"
        android:label="fragment_form_d_j"
        tools:layout="@layout/fragment_form_d_j">
        <action
            android:id="@+id/action_formDJ_to_dashboardDJ"
            app:destination="@id/dashboardDJ" />
    </fragment>

    <fragment
        android:id="@+id/dashboardDJ"
        android:name="com.example.bpmnow.ui.dj.dashboardDJ"
        android:label="Dashboard"
        tools:layout="@layout/fragment_dashboard_d_j" />

    <fragment
        android:id="@+id/requestsDJ"
        android:name="com.example.bpmnow.ui.dj.requestsDJ"
        android:label="Requests"
        tools:layout="@layout/fragment_requests_d_j">
        <action
            android:id="@+id/action_requestsDJ_to_trackReviewsDJ"
            app:destination="@id/trackReviewsDJ" />
    </fragment>

    <fragment
        android:id="@+id/trackReviewsDJ"
        android:name="com.example.bpmnow.ui.dj.trackReviewsDJ"
        android:label="Track Reviews"
        tools:layout="@layout/fragment_track_reviews_dj" />

    <fragment
        android:id="@+id/clubsDJ"
        android:name="com.example.bpmnow.ui.dj.clubsDJ"
        android:label="Clubs"
        tools:layout="@layout/fragment_clubs_d_j" />

    <fragment
        android:id="@+id/profileDJ"
        android:name="com.example.bpmnow.ui.dj.profileDJ"
        android:label="Profile"
        tools:layout="@layout/fragment_profile_d_j" />
</navigation>
